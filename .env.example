# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/productivity_rewards"

# Firebase Admin SDK (from Project Settings > Service Accounts > Generate new private key)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Paste the private key value — keep the quotes, replace literal \n with newlines if needed
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
