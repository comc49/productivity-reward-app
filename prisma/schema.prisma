datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(uuid())
  firebaseUid  String   @unique
  email        String?
  displayName  String?
  watchBalance Int      @default(0)
  createdAt    DateTime @default(now())
  tasks        Task[]
  wallet       Wallet?
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  coinReward  Int
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model Reward {
  id          String   @id @default(uuid())
  title       String
  description String?
  coinCost    Int
  isRedeemed  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Wallet {
  id      String @id @default(uuid())
  balance Int    @default(0)
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id])
}
