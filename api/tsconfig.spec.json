{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../out-tsc/api-spec",
    "types": ["vitest/globals", "node"],
    "emitDeclarationOnly": false,
    "composite": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021"
  },
  "include": ["src/**/*.spec.ts"]
}
